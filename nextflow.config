// ─── Diagnostic reports (enabled by default for troubleshooting) ────
// Written to ${params.outdir}/reports/ so they don't clutter the launch dir.
timeline.enabled = true
timeline.file    = "${params.outdir}/reports/timeline.html"
report.enabled   = true
report.file      = "${params.outdir}/reports/report.html"
trace.enabled    = true
trace.file       = "${params.outdir}/reports/trace.txt"
dag.enabled      = true
dag.file         = "${params.outdir}/reports/dag.html"

profiles {
    local {
        process.executor = 'local'
    }
    prod {
        process {
            executor = 'slurm'
            errorStrategy = 'finish'
            queue = 'production'
            memory = { task.memory ?: '16 GB' }
            time = { task.time ?: '1d' }
            cpus = { task.cpus ?: 1 }
            beforeScript = '''
                  echo "SLURM Job ID: $SLURM_JOB_ID"
            '''
            clusterOptions = {
                def base = '--mail-type=FAIL,REQUEUE,INVALID_DEPEND,ARRAY_TASKS'
                params.notify_email ? "${base} --mail-user=${params.notify_email}" : base
            }
            // ICEBERG_TRANSFORM uses retry + --skip-existing for OOM recovery.
            // Without this override, the config-level 'finish' would suppress retries.
            withName:ICEBERG_TRANSFORM {
                errorStrategy = 'retry'
                maxRetries = 1
            }
        }
    }
    short {
        process {
            executor = 'slurm'
            queue = 'short'
            memory = { task.memory ?: '4 GB' }
            time = { task.time ?: '4h' }
            cpus = { task.cpus ?: 1 }
            beforeScript = '''
                  echo "SLURM Job ID: $SLURM_JOB_ID"
            '''
            clusterOptions = {
                def base = '--mail-type=FAIL,REQUEUE,INVALID_DEPEND,ARRAY_TASKS'
                params.notify_email ? "${base} --mail-user=${params.notify_email}" : base
            }
        }
    }
}
