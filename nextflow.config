// ─── Pipeline metadata ──────────────────────────────────────────────
manifest {
    name            = 'uniprot-lake'
    mainScript      = 'upjson2lake.nf'
    nextflowVersion = '>=23.04'
    version         = '1.0.0'
    description     = 'UniProtKB JSON → sorted Parquet data lake'
}

// ─── Diagnostic reports (enabled by default for troubleshooting) ────
// Written to ${params.outdir}/reports/ so they don't clutter the launch dir.
timeline.enabled = true
timeline.file    = "${params.outdir}/reports/timeline.html"
report.enabled   = true
report.file      = "${params.outdir}/reports/report.html"
trace.enabled    = true
trace.file       = "${params.outdir}/reports/trace.txt"
dag.enabled      = true
dag.file         = "${params.outdir}/reports/dag.html"

profiles {
    local {
        process.executor = 'local'
    }
    prod {
        process {
            executor = 'slurm'
            errorStrategy = 'finish'
            queue = 'production'
            memory = { task.memory ?: '16 GB' }
            time = { task.time ?: '1d' }
            cpus = { task.cpus ?: 1 }
            beforeScript = '''
                  echo "SLURM Job ID: $SLURM_JOB_ID"
            '''
            clusterOptions = {
                def base = '--mail-type=FAIL,REQUEUE,INVALID_DEPEND,ARRAY_TASKS'
                params.notify_email ? "${base} --mail-user=${params.notify_email}" : base
            }
            // PARQUET_TRANSFORM: retry on OOM with 50% more memory.
            // --skip-existing in the script means already-written tables
            // are skipped on retry (output is published to release_dir,
            // so it persists across Nextflow work directories).
            withName:PARQUET_TRANSFORM {
                errorStrategy = 'retry'
                maxRetries = 1
                memory = { task.memory * task.attempt }
            }
        }
    }
    short {
        process {
            executor = 'slurm'
            errorStrategy = 'finish'
            queue = 'short'
            memory = { task.memory ?: '4 GB' }
            time = { task.time ?: '4h' }
            cpus = { task.cpus ?: 1 }
            beforeScript = '''
                  echo "SLURM Job ID: $SLURM_JOB_ID"
            '''
            clusterOptions = {
                def base = '--mail-type=FAIL,REQUEUE,INVALID_DEPEND,ARRAY_TASKS'
                params.notify_email ? "${base} --mail-user=${params.notify_email}" : base
            }
        }
    }
}
